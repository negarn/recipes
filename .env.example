# Copy these values into `.env.local` and keep `.env.local` uncommitted.
# Optional: override the default local persistence directory.
# RECIPE_PREFERENCES_DATA_DIR=/absolute/path/to/recipes-data

# Optional: set the externally reachable origin for a protected deployment.
# Use the exact scheme and host, such as https://recipes.example.com.
# RECIPE_PUBLIC_ORIGIN=https://recipes.example.com

# Optional: require Google sign-in before opening the app.
# Set the exact Google account that may sign in. When this is set, Google auth
# is enforced for app pages and API routes.
# RECIPE_AUTH_ALLOWED_EMAIL=you@example.com
# RECIPE_AUTH_GOOGLE_CLIENT_ID=
# RECIPE_AUTH_GOOGLE_CLIENT_SECRET=
# RECIPE_AUTH_SESSION_SECRET=replace-with-a-long-random-string

# Cloud sync credentials are optional.
# Create an OAuth app in the provider console, then fill in the matching values.
RECIPE_GOOGLE_DRIVE_CLIENT_ID=
RECIPE_GOOGLE_DRIVE_CLIENT_SECRET=
RECIPE_DROPBOX_CLIENT_ID=
RECIPE_DROPBOX_CLIENT_SECRET=
