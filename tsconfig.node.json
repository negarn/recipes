{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "server/**/*.ts",
    "src/data/**/*.ts",
    "src/helpers/cloudSyncData.ts",
    "src/helpers/cloudSyncRoutes.ts",
    "src/helpers/asyncQueue.ts",
    "src/helpers/ingredientText.ts",
    "src/helpers/mealPlan.ts",
    "src/helpers/mealPlanData.ts",
    "src/helpers/customRecipes.ts",
    "src/helpers/bookmarkText.ts",
    "src/helpers/normalization.ts",
    "src/helpers/recipePreferenceData.ts",
    "src/helpers/recipePreferenceRoutes.ts",
    "src/helpers/recipePreferenceStores.ts",
    "src/types/**/*.ts"
  ]
}
